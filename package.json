{
  "name": "tasks",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Kanban task board for any iterate project's /repos/config — a standalone TanStack Start app on Cloudflare Workers, mutually authenticated with os.iterate.com",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "deploy": "vite build && wrangler deploy"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.10",
    "@tanstack/react-start": "^1.168.18",
    "capnweb": "npm:@iterate-com/capnweb@^0.10.0",
    "iterate": "https://pkg.pr.new/iterate/iterate/iterate@b62c471f4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.43.0",
    "@cloudflare/workers-types": "^4.20260621.1",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.9.2",
    "vite": "^8.0.16",
    "wrangler": "4.107.0"
  }
}
